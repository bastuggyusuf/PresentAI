# ───────────────────────────────────────────────────────────
# PresentAI Backend — Ortam Değişkenleri Şablonu
# ───────────────────────────────────────────────────────────
# Bu dosyayı `.env` olarak kopyala ve değerleri kendin doldur.
# `.env` dosyası `.gitignore`'da → asla commit edilmez.
#
#   cp .env.example .env       (Linux/Mac)
#   copy .env.example .env     (Windows CMD)
#   Copy-Item .env.example .env  (PowerShell)
# ───────────────────────────────────────────────────────────

# Google Gemini API anahtarı
# Edin: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# OpenRouter LLM (Ücretsiz ve Limitsiz)
# Edin: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=openrouter/free

# Backend'e erişim için paylaşılan API anahtarı
# Boş bırakılırsa auth devre dışı (dev mode)
PRESENTAI_API_KEY=

# CORS — izin verilen origin'ler (virgül ile ayrılır)
# Production'da frontend domain'inizi yazın
ALLOWED_ORIGINS=*

# Veritabanı yolu
DB_PATH=web_presentations.sqlite3
VECTOR_DB_PATH=./vector_db

# Seed data — ilk başlatmada örnek veri eklensin mi?
SEED_DATA=true
